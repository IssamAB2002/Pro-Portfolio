DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key-min-50-chars
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com
DJANGO_ADMIN_URL=admin/
DJANGO_CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://your-frontend-domain.com
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_LOG_LEVEL=INFO
DB_NAME=portfolio-db
DB_USER=postgres
DB_PASS=replace-me
DB_HOST=/cloudsql/your-project:your-region:your-instance
DB_PORT=5432
USE_GCS_STATIC=True
GS_BUCKET_NAME=your-static-bucket-name
GS_PROJECT_ID=your-gcp-project-id
GS_QUERYSTRING_AUTH=False
REDIS_URL=redis://:your-password@your-redis-host:6379/0
